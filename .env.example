# --- Database (SQLite via Turso/libSQL, used by Drizzle) ---
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# --- Auth (Better Auth) ---
BETTER_AUTH_SECRET=            # random 32+ char secret, e.g. `openssl rand -base64 32`
WEBSITE_URL=                   # public URL of the deployed app, e.g. https://yogawithlisa.com

# --- AI Gateway (MindShift / Claude) ---
AI_GATEWAY_BASE_URL=
AI_GATEWAY_API_KEY=

# --- File storage (S3-compatible, used for any uploaded/generated assets) ---
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Twilio (SMS reminders) ---
# Without these set, reminders are simulated (logged to the server console) instead of sent.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=            # your Twilio phone number, e.g. +15551234567

# --- Cron protection ---
# Shared secret required in the `x-cron-secret` header when calling POST /api/reminders/send-daily
CRON_SECRET=

NODE_ENV=development
