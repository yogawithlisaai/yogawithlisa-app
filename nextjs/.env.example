# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, used by the reminder cron to read all opt-ins (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (MindShift AI chat) ---
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-sonnet-4-6
MINDSHIFT_MODEL=

# --- Twilio (SMS reminders) ---
# Without these set, reminders are simulated (logged to the server console) instead of sent.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Cron protection ---
# On Vercel, set CRON_SECRET in the project env — Vercel Cron sends it as `Authorization: Bearer <secret>`.
CRON_SECRET=
